# Kopieren Sie diese Datei nach .env und tragen Sie Ihre Werte ein.
#
# Pflicht:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SALON_EMAIL=empfang@friseursalon-henkes.de

# Optional:
# Absender-Adresse. Default ist "Friseursalon Henkes <onboarding@resend.dev>"
# (funktioniert sofort, aber unprofessionell und landet eher im Spam).
# Empfehlung: Eigene Domain bei Resend verifizieren und z.B. eintragen:
# EMAIL_FROM=Friseursalon Henkes <noreply@friseursalon-henkes.de>

# Wenn gesetzt, wird diese Adresse als Reply-To für Kunden-Mails verwendet,
# damit Antworten an die echte Salon-Mailbox gehen (sonst geht's an SALON_EMAIL).
# EMAIL_USER=salon@friseursalon-henkes.de

# Optional (für lokale Entwicklung): erlaubte Origin-URLs für CORS.
# ALLOWED_ORIGINS=https://friseursalon-henkes-website.netlify.app
