# Kopieren Sie diese Datei nach .env und tragen Sie Ihre Werte ein.
#
# Pflicht:
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
SALON_EMAIL=empfang@friseursalon-henkes.de

# Optional:
# Absender-Adresse. Default ist "Friseursalon Henkes <onboarding@resend.dev>"
# (funktioniert sofort, aber unprofessionell und landet eher im Spam).
# Empfehlung: Eigene Domain bei Resend verifizieren und z.B. eintragen:
# EMAIL_FROM=Friseursalon Henkes <noreply@friseursalon-henkes.de>

# Wenn gesetzt, wird diese Adresse als Reply-To für Kunden-Mails verwendet,
# damit Antworten an die echte Salon-Mailbox gehen (sonst geht's an SALON_EMAIL).
# EMAIL_USER=salon@friseursalon-henkes.de

# Optional (für lokale Entwicklung): erlaubte Origin-URLs für CORS.
# ALLOWED_ORIGINS=https://friseursalon-henkes-website.netlify.app

# Basis-URL für Stornier-Links in den Kunden-Mails.
# Wird normalerweise automatisch aus der Request abgeleitet. Bei Reverse-Proxy
# oder wenn die Mails einen anderen Host nennen sollen als der Buchungs-Host,
# hier explizit setzen (ohne Slash am Ende).
# PUBLIC_BASE_URL=https://friseursalon-henkes-backend.onrender.com

# Pflicht für den Admin-Bereich (/admin.html): HTTP Basic Auth.
# Ohne diese beiden Werte ist die Admin-Seite komplett gesperrt – nicht
# versehentlich offen.
ADMIN_USER=henkes
ADMIN_PASSWORD=ein-starkes-passwort-aus-einem-passwort-manager

# Optional: Shared-Secret fuer den taeglichen Cron-Endpoint
# /api/cron/daily-digest. Wenn gesetzt, kann ein externer Cron (z.B.
# cron-job.org, GitHub Actions) morgens diese URL aufrufen und der Salon
# bekommt eine Mail mit den heutigen Terminen. Nebeneffekt: weckt Render
# auf, sodass der erste Kunden-Klick keinen Cold-Start mehr abkriegt.
#
# Setup cron-job.org:
#   URL: https://friseursalon-henkes-backend.onrender.com/api/cron/daily-digest?secret=DEIN_SECRET
#   Zeitplan: jeden Tag um 07:00 Berliner Zeit
#   Methode: GET
# CRON_SECRET=lange-zufaellige-zeichenkette-aus-einem-passwort-manager
